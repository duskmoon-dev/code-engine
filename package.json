  "bugs": "https://github.com/duskmoon-dev/code-engine/issues",
  "keywords": ["codemirror", "editor", "code-editor", "lezer", "syntax-highlighting", "language-support"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
