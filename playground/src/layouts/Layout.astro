---
interface Props {
  title: string
  description?: string
  wide?: boolean
}

const { title, wide = false, description = 'Deep fork of CodeMirror 6 + Lezer — single package, zero dependencies' } = Astro.props
const base = import.meta.env.BASE_URL
const fullTitle = `${title} — @duskmoon-dev/code-engine`
const path = Astro.url.pathname
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <meta property="og:title" content={fullTitle}>
  <meta property="og:description" content={description}>
  <meta property="og:type" content="website">
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content={fullTitle}>
  <meta name="twitter:description" content={description}>
  <meta property="og:url" content={Astro.url.href}>
  <link rel="canonical" href={Astro.url.href}>
  <title>{fullTitle}</title>
  <meta name="theme-color" content="#0d1117">
  <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`}>
</head>
<body>
  <a href="#main-content" class="skip-link">Skip to content</a>
  <nav>
    <a href={base} class="nav-brand">code-engine</a>
    <div class="nav-links">
      <a href={`${base}docs`} aria-current={path.includes('/docs') ? 'page' : undefined}>Docs</a>
      <a href={`${base}playground`} aria-current={path.includes('/playground') ? 'page' : undefined}>Playground</a>
      <a href="https://github.com/duskmoon-dev/code-engine" target="_blank" rel="noopener">GitHub</a>
    </div>
  </nav>
  <main id="main-content" class:list={[{ wide }]}>
    <slot />
  </main>
  <footer>
    <p>&copy; {new Date().getFullYear()} duskmoon-dev &middot; MIT License</p>
  </footer>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

<style>
  .skip-link {
    position: absolute;
    top: -100%;
    left: 0;
    padding: 0.5rem 1rem;
    background: var(--color-accent);
    color: var(--color-bg);
    z-index: 100;
    font-weight: 600;
  }
  .skip-link:focus {
    top: 0;
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-md) var(--space-lg);
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .nav-brand {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--color-accent);
  }

  .nav-links {
    display: flex;
    gap: var(--space-md);
  }

  .nav-links a {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    transition: color 0.15s;
  }
  .nav-links a:hover,
  .nav-links a:focus-visible {
    color: var(--color-text);
    text-decoration: none;
  }
  .nav-links a:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: 2px;
  }
  .nav-links a[aria-current="page"] {
    color: var(--color-text);
    font-weight: 600;
  }

  main {
    max-width: 48rem;
    margin: 0 auto;
    padding: var(--space-lg);
  }
  main.wide {
    max-width: 100%;
  }

  footer {
    text-align: center;
    padding: var(--space-lg);
    color: var(--color-text-muted);
    font-size: 0.85rem;
    border-top: 1px solid var(--color-border);
  }
</style>
