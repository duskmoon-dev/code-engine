---
import Layout from '../layouts/Layout.astro'
import ExportList from '../components/ExportList.astro'
import Changelog from '../components/Changelog.astro'
import pkg from '../../../package.json'
const base = import.meta.env.BASE_URL
const exportCount = Object.keys(pkg.exports).length
---
<Layout title="API Reference" description={`Full API reference for all ${exportCount} subpath exports in @duskmoon-dev/code-engine, organized by category with changelog.`}>
  <h1>API Reference</h1>
  <p>All exports from <code>@duskmoon-dev/code-engine</code>, organized by category.
    <a href={`${base}playground`} class="try-link">→ Try in Playground</a>
  </p>

  <section class="exports">
    <h2>Exports</h2>
    <ExportList />
  </section>

  <section>
    <h2>Changelog</h2>
    <Changelog />
  </section>

  <section class="links">
    <h2>Links</h2>
    <ul>
      <li><a href="https://www.npmjs.com/package/@duskmoon-dev/code-engine" target="_blank" rel="noopener">npm Package</a></li>
      <li><a href="https://github.com/duskmoon-dev/code-engine" target="_blank" rel="noopener">GitHub Repository</a></li>
    </ul>
  </section>
</Layout>

<style>
  h1 {
    margin-bottom: var(--space-sm);
  }
  .try-link {
    margin-left: var(--space-sm);
    font-size: 0.9em;
    white-space: nowrap;
  }
  h2 {
    color: var(--color-accent);
    margin-top: var(--space-lg);
    margin-bottom: var(--space-sm);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 0.3rem;
  }
  section {
    margin-bottom: var(--space-lg);
  }
  ul {
    padding-left: 1.5rem;
  }
  li {
    margin-bottom: 0.25rem;
  }
</style>
