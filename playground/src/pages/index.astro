---
import Layout from '../layouts/Layout.astro'
import pkg from '../../../package.json'
const version = pkg.version
---
<Layout title="Home">
  <div class="hero">
    <h1>@duskmoon-dev/code-engine</h1>
    <p class="tagline">Deep fork of CodeMirror 6 + Lezer — single package, zero dependencies</p>
    <div class="badges">
      <span class="badge">v{version}</span>
      <span class="badge">MIT License</span>
      <span class="badge">Zero Dependencies</span>
    </div>
  </div>

  <div class="features">
    <div class="feature">
      <h3>43 Subpath Exports</h3>
      <p>Tree-shakeable imports for state, view, language, 22 language packs, themes, and more.</p>
    </div>
    <div class="feature">
      <h3>22 Languages</h3>
      <p>JavaScript, TypeScript, Python, Rust, Go, HTML, CSS, and 15 more with full syntax highlighting.</p>
    </div>
    <div class="feature">
      <h3>Single Package</h3>
      <p>All 52 upstream CodeMirror + Lezer modules vendored into one install. No dependency tree.</p>
    </div>
  </div>

  <section>
    <h2>Install</h2>
    <pre><code>bun add @duskmoon-dev/code-engine</code></pre>
  </section>

  <section>
    <h2>Quick Start</h2>
    <pre><code>{`import { EditorState } from "@duskmoon-dev/code-engine/state"
import { EditorView } from "@duskmoon-dev/code-engine/view"
import { basicSetup } from "@duskmoon-dev/code-engine/setup"
import { javascript } from "@duskmoon-dev/code-engine/lang/javascript"

new EditorView({
  state: EditorState.create({
    doc: 'console.log("Hello!")',
    extensions: [basicSetup, javascript()],
  }),
  parent: document.getElementById("editor"),
})`}</code></pre>
    <a href={`${import.meta.env.BASE_URL}playground#lang=javascript`} class="try-btn">Try in Playground →</a>
  </section>

  <nav class="page-links">
    <a href={`${import.meta.env.BASE_URL}docs`} class="link-card">
      <h3>API Reference</h3>
      <p>Browse all 43 exports and the changelog</p>
    </a>
    <a href={`${import.meta.env.BASE_URL}playground`} class="link-card">
      <h3>Playground</h3>
      <p>Try the editor with 23 languages and themes</p>
    </a>
  </nav>
</Layout>

<script>
  document.querySelectorAll('pre').forEach(pre => {
    const btn = document.createElement('button')
    btn.textContent = 'Copy'
    btn.setAttribute('aria-label', 'Copy code to clipboard')
    btn.className = 'copy-btn'
    btn.addEventListener('click', async () => {
      const code = pre.querySelector('code')?.textContent ?? ''
      try {
        await navigator.clipboard.writeText(code)
        btn.textContent = 'Copied!'
      } catch {
        btn.textContent = 'Failed'
      }
      setTimeout(() => { btn.textContent = 'Copy' }, 1500)
    })
    pre.style.position = 'relative'
    pre.appendChild(btn)
  })
</script>

<style>
  .hero {
    text-align: center;
    padding: var(--space-lg) 0;
  }
  .hero h1 {
    font-family: var(--font-mono);
    font-size: 1.8rem;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }
  .tagline {
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
  }
  .badges {
    display: flex;
    gap: var(--space-sm);
    justify-content: center;
    flex-wrap: wrap;
  }
  .badge {
    display: inline-block;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: 0.2rem 0.6rem;
    border-radius: 12px;
    font-size: 0.85rem;
  }
  .features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(12rem, 1fr));
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }
  .feature {
    padding: var(--space-md);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }
  .feature h3 {
    color: var(--color-accent);
    font-size: 1rem;
    margin-bottom: 0.3rem;
  }
  .feature p {
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }
  section {
    margin-bottom: var(--space-lg);
  }
  h2 {
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 0.3rem;
  }
  .page-links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
    gap: var(--space-md);
    margin-top: var(--space-lg);
  }
  .link-card {
    display: block;
    padding: var(--space-md);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    transition: border-color 0.15s;
  }
  .link-card:hover,
  .link-card:focus-visible {
    border-color: var(--color-accent);
    text-decoration: none;
  }
  .link-card:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
  .link-card h3 {
    color: var(--color-text);
    margin-bottom: 0.25rem;
  }
  .link-card p {
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }
  .try-btn {
    display: inline-block;
    margin-top: var(--space-sm);
    padding: 0.4rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    font-size: 0.9rem;
    transition: border-color 0.15s, color 0.15s;
  }
  .try-btn:hover {
    border-color: var(--color-accent);
    text-decoration: none;
  }
  .try-btn:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
  :global(.copy-btn) {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    padding: 0.2rem 0.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    color: var(--color-text-muted);
    font-size: 0.75rem;
    font-family: var(--font-sans);
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
  }
  :global(.copy-btn:hover) {
    color: var(--color-text);
    border-color: var(--color-accent);
  }
</style>
