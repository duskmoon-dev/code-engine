---
const pkg = '@duskmoon-dev/code-engine'

const categories = [
  {
    name: 'Root',
    exports: [{ path: '.', description: 'Barrel re-export of core modules' }],
  },
  {
    name: 'Core',
    exports: [
      { path: 'state' },
      { path: 'view' },
      { path: 'language' },
      { path: 'commands' },
      { path: 'search' },
      { path: 'autocomplete' },
      { path: 'lint' },
      { path: 'collab' },
      { path: 'merge' },
      { path: 'lsp' },
      { path: 'language-data' },
    ],
  },
  {
    name: 'Parser',
    exports: [
      { path: 'parser/common' },
      { path: 'parser/lr' },
      { path: 'parser/highlight' },
    ],
  },
  {
    name: 'Languages',
    exports: [
      { path: 'lang/javascript' },
      { path: 'lang/python' },
      { path: 'lang/html' },
      { path: 'lang/css' },
      { path: 'lang/json' },
      { path: 'lang/markdown' },
      { path: 'lang/xml' },
      { path: 'lang/sql' },
      { path: 'lang/rust' },
      { path: 'lang/go' },
      { path: 'lang/java' },
      { path: 'lang/cpp' },
      { path: 'lang/php' },
      { path: 'lang/sass' },
      { path: 'lang/less' },
      { path: 'lang/yaml' },
      { path: 'lang/angular' },
      { path: 'lang/vue' },
      { path: 'lang/liquid' },
      { path: 'lang/wast' },
      { path: 'lang/jinja' },
      { path: 'lang/lezer' },
      { path: 'lang/legacy/*', description: 'StreamLanguage.define() based legacy modes' },
    ],
  },
  {
    name: 'Themes',
    exports: [
      { path: 'theme/one-dark' },
      { path: 'theme/duskmoon' },
    ],
  },
  {
    name: 'Keymaps',
    exports: [
      { path: 'keymaps/vim' },
      { path: 'keymaps/emacs' },
    ],
  },
  {
    name: 'Setup',
    exports: [
      { path: 'setup', description: 'basicSetup, minimalSetup extension arrays' },
    ],
  },
]
---

{categories.map(cat => (
  <div class="category">
    <h3>{cat.name} <span class="count">({cat.exports.length})</span></h3>
    <table>
      <tbody>
        {cat.exports.map(exp => (
          <tr>
            <td><code>{pkg}/{exp.path}</code></td>
            {exp.description && <td class="desc">{exp.description}</td>}
          </tr>
        ))}
      </tbody>
    </table>
  </div>
))}

<style>
  .category {
    margin-bottom: var(--space-lg);
  }
  h3 {
    margin-bottom: var(--space-sm);
  }
  .count {
    color: var(--color-text-muted);
    font-weight: normal;
    font-size: 0.9em;
  }
  table {
    width: 100%;
    border-collapse: collapse;
  }
  td {
    padding: 0.4rem 0.6rem;
    border-bottom: 1px solid var(--color-border);
    font-size: 0.9rem;
  }
  .desc {
    color: var(--color-text-muted);
  }
</style>
