---
import changelog from '../../../CHANGELOG.md?raw'

// Basic markdown-to-HTML conversion at build time (no dependency needed)
function renderMarkdown(md: string): string {
  // First pass: extract fenced code blocks to protect them from inline processing
  const codeBlocks: string[] = []
  let processed = md.replace(/^```(\w*)\n([\s\S]*?)^```$/gm, (_match, lang, code) => {
    const idx = codeBlocks.length
    const escaped = code.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
    codeBlocks.push(`<pre><code${lang ? ` class="language-${lang}"` : ''}>${escaped}</code></pre>`)
    return `%%CODEBLOCK_${idx}%%`
  })

  processed = processed
    // headings (with id anchors on h2/h3 for deep linking)
    .replace(/^### (.+)$/gm, (_m, t) => `<h4 id="cl-${t.toLowerCase().replace(/[^a-z0-9]+/g, '-')}">${t}</h4>`)
    .replace(/^## (.+)$/gm, (_m, t) => `<h3 id="cl-${t.toLowerCase().replace(/[^a-z0-9]+/g, '-')}">${t}</h3>`)
    .replace(/^# (.+)$/gm, (_m, t) => `<h2 id="cl-${t.toLowerCase().replace(/[^a-z0-9]+/g, '-')}">${t}</h2>`)
    // horizontal rules
    .replace(/^(?:---|\*\*\*|___)\s*$/gm, '<hr>')
    // blockquotes (consecutive > lines grouped, preserving line breaks)
    .replace(/(^>.*\n?)+/gm, (match) => {
      const lines = match.replace(/^> ?/gm, '').trim().split('\n')
      const paragraphs = lines.reduce<string[][]>((acc, line) => {
        if (line.trim() === '') acc.push([])
        else (acc.at(-1) ?? (acc.push([]), acc.at(-1)!)).push(line)
        return acc
      }, [[]])
      const html = paragraphs.filter(p => p.length).map(p => `<p>${p.join('<br>')}</p>`).join('')
      return `<blockquote>${html}</blockquote>`
    })
    // bold & italic
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.+?)\*/g, '<em>$1</em>')
    // inline code
    .replace(/`([^`]+)`/g, '<code>$1</code>')
    // links
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener">$1</a>')
    // unordered lists
    .replace(/^- (.+)$/gm, '<li>$1</li>')
    // ordered lists
    .replace(/^\d+\. (.+)$/gm, '<li>$1</li>')
    // wrap consecutive <li> in <ul>
    .replace(/((?:<li>.*<\/li>\n?)+)/g, '<ul>$1</ul>')
    // paragraphs: blank-line separated blocks that aren't already HTML
    .replace(/^(?!<[a-z]|%%CODEBLOCK)([\s\S]+?)(?=\n\n|$)/gm, (match) => {
      const trimmed = match.trim()
      if (!trimmed || trimmed.startsWith('<') || trimmed.startsWith('%%CODEBLOCK')) return match
      return `<p>${trimmed}</p>`
    })

  // Restore code blocks
  for (let i = 0; i < codeBlocks.length; i++) {
    processed = processed.replace(`%%CODEBLOCK_${i}%%`, codeBlocks[i])
  }

  return processed
}

const sections = changelog.split('\n## ').map((s, i) => i === 0 ? s : '## ' + s)
const rendered = sections.map(s => renderMarkdown(s))
---

<div class="changelog">
  {rendered.map(html => (
    <section set:html={html} />
  ))}
</div>

<style>
  .changelog {
    margin-top: var(--space-md);
  }
  .changelog :global(section) {
    margin-bottom: var(--space-lg);
  }
  .changelog :global(h2) {
    font-size: 1.5rem;
    margin-bottom: var(--space-sm);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--space-sm);
  }
  .changelog :global(h3) {
    font-size: 1.2rem;
    margin: var(--space-md) 0 var(--space-sm);
  }
  .changelog :global(h4) {
    font-size: 1rem;
    margin: var(--space-sm) 0;
  }
  .changelog :global(ul) {
    padding-left: 1.5rem;
    margin: var(--space-sm) 0;
  }
  .changelog :global(li) {
    margin-bottom: 0.25rem;
  }
  .changelog :global(code) {
    background: var(--color-surface);
    padding: 0.15rem 0.35rem;
    border-radius: 3px;
    font-family: var(--font-mono);
    font-size: 0.9em;
  }
  .changelog :global(p) {
    margin: var(--space-sm) 0;
  }
  .changelog :global(pre) {
    background: var(--color-code-bg, var(--color-surface));
    padding: var(--space-md);
    border-radius: var(--radius, 6px);
    overflow-x: auto;
    margin: var(--space-sm) 0;
  }
  .changelog :global(pre code) {
    background: none;
    padding: 0;
  }
  .changelog :global(a) {
    color: var(--color-accent);
  }
  .changelog :global(a:hover) {
    text-decoration: underline;
  }
  .changelog :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding: var(--space-sm) var(--space-md);
    margin: var(--space-sm) 0;
    color: var(--color-text-muted);
    background: var(--color-surface);
    border-radius: 0 var(--radius) var(--radius) 0;
  }
  .changelog :global(blockquote p) {
    margin: 0;
  }
  .changelog :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-lg) 0;
  }
</style>
